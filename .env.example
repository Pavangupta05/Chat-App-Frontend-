# Frontend environment variables

# Backend API URL (e.g., http://localhost:5000, https://your-api.com)
VITE_API_URL=http://localhost:5000

# WebSocket/Socket.io URL (usually same as API URL)
# If not set, defaults to VITE_API_URL
VITE_SOCKET_URL=http://localhost:5000

# Current user (for demo/testing)
VITE_CHAT_USERNAME=Pavan
